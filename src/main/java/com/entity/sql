-- 1. DATABASE INIT
IF NOT EXISTS (SELECT * FROM sys.databases WHERE name = 'S_Mall')
BEGIN
    CREATE DATABASE S_Mall;
END
GO

USE S_Mall;
GO

-- 2. USERS & ROLES
CREATE TABLE roles (
    id BIGINT IDENTITY(1,1) PRIMARY KEY,
    name NVARCHAR(50) NOT NULL UNIQUE,
    description NVARCHAR(255)
);

CREATE TABLE users (
    id BIGINT IDENTITY(1,1) PRIMARY KEY,
    email NVARCHAR(255) UNIQUE NOT NULL,
    password NVARCHAR(255) NOT NULL,
    role_id BIGINT,
    is_active BIT DEFAULT 1,
    created_at DATETIME2 DEFAULT GETDATE(),
    updated_at DATETIME2 DEFAULT GETDATE(),
    FOREIGN KEY (role_id) REFERENCES roles(id)
);

CREATE TABLE user_profiles (
    id BIGINT IDENTITY(1,1) PRIMARY KEY,
    user_id BIGINT UNIQUE NOT NULL,
    full_name NVARCHAR(255),
    phone_number NVARCHAR(20),
    gender BIT, -- 0: Female, 1: Male
    address NVARCHAR(MAX),
    avatar_url NVARCHAR(MAX),
    date_of_birth DATE,
    FOREIGN KEY (user_id) REFERENCES users(id) ON DELETE CASCADE
);

-- 3. SHOPS
CREATE TABLE shops (
    id BIGINT IDENTITY(1,1) PRIMARY KEY,
    user_id BIGINT UNIQUE NOT NULL,
    name NVARCHAR(255) NOT NULL,
    slug NVARCHAR(255) UNIQUE,
    description NVARCHAR(MAX),
    logo_url NVARCHAR(MAX),
    rating_average DECIMAL(3,2) DEFAULT 0.0,
    is_active BIT DEFAULT 1,
    created_at DATETIME2 DEFAULT GETDATE(),
    FOREIGN KEY (user_id) REFERENCES users(id) ON DELETE CASCADE
);

-- 4. CATEGORIES
CREATE TABLE categories (
    id BIGINT IDENTITY(1,1) PRIMARY KEY,
    parent_id BIGINT NULL,
    name NVARCHAR(255) NOT NULL,
    slug NVARCHAR(255) UNIQUE,
    icon_url NVARCHAR(MAX),
    is_active BIT DEFAULT 1,
    FOREIGN KEY (parent_id) REFERENCES categories(id)
);

-- 5. PRODUCTS & VARIANTS
CREATE TABLE products (
    id BIGINT IDENTITY(1,1) PRIMARY KEY,
    shop_id BIGINT NOT NULL,
    category_id BIGINT,
    name NVARCHAR(255) NOT NULL,
    slug NVARCHAR(255) UNIQUE,
    description NVARCHAR(MAX),
    status NVARCHAR(50) DEFAULT 'PUBLISHED', -- DRAFT, PUBLISHED, BANNED
    view_count INT DEFAULT 0,
    sold_count INT DEFAULT 0,
    average_rating DECIMAL(3,2) DEFAULT 0.0,
    is_active BIT DEFAULT 1,
    created_at DATETIME2 DEFAULT GETDATE(),
    updated_at DATETIME2 DEFAULT GETDATE(),
    FOREIGN KEY (shop_id) REFERENCES shops(id) ON DELETE CASCADE,
    FOREIGN KEY (category_id) REFERENCES categories(id)
);

CREATE TABLE product_variants (
    id BIGINT IDENTITY(1,1) PRIMARY KEY,
    product_id BIGINT NOT NULL,
    sku NVARCHAR(100) UNIQUE,
    price DECIMAL(12,2) NOT NULL,
    discount_price DECIMAL(12,2) NULL, -- FLASH SALE PRICE
    stock INT NOT NULL DEFAULT 0,
    attributes_json NVARCHAR(MAX), -- Flexible attributes (Color, Size, Capacity, etc.)
    FOREIGN KEY (product_id) REFERENCES products(id) ON DELETE CASCADE
);

CREATE TABLE product_images (
    id BIGINT IDENTITY(1,1) PRIMARY KEY,
    product_id BIGINT NOT NULL,
    url NVARCHAR(MAX) NOT NULL,
    is_main BIT DEFAULT 0,
    FOREIGN KEY (product_id) REFERENCES products(id) ON DELETE CASCADE
);

-- 6. CART & ORDERS
CREATE TABLE cart_items (
    id BIGINT IDENTITY(1,1) PRIMARY KEY,
    user_id BIGINT NOT NULL,
    product_variant_id BIGINT NOT NULL,
    quantity INT NOT NULL DEFAULT 1,
    FOREIGN KEY (user_id) REFERENCES users(id) ON DELETE CASCADE,
    FOREIGN KEY (product_variant_id) REFERENCES product_variants(id) ON DELETE CASCADE,
    CONSTRAINT unique_cart UNIQUE (user_id, product_variant_id)
);

CREATE TABLE orders (
    id BIGINT IDENTITY(1,1) PRIMARY KEY,
    user_id BIGINT NOT NULL,
    order_code NVARCHAR(50) UNIQUE NOT NULL, -- Format: SM-XXXXXXXX
    total_price DECIMAL(12,2) NOT NULL,
    status NVARCHAR(50) DEFAULT 'PENDING', -- PENDING, CONFIRMED, SHIPPING, DELIVERED, CANCELLED
    shipping_address NVARCHAR(MAX) NOT NULL,
    payment_method NVARCHAR(50) DEFAULT 'COD',
    note NVARCHAR(MAX),
    created_at DATETIME2 DEFAULT GETDATE(),
    updated_at DATETIME2 DEFAULT GETDATE(),
    FOREIGN KEY (user_id) REFERENCES users(id)
);

CREATE TABLE order_items (
    id BIGINT IDENTITY(1,1) PRIMARY KEY,
    order_id BIGINT NOT NULL,
    product_variant_id BIGINT NOT NULL,
    price_at_purchase DECIMAL(12,2) NOT NULL, -- For Financial Audit
    quantity INT NOT NULL,
    FOREIGN KEY (order_id) REFERENCES orders(id) ON DELETE CASCADE,
    FOREIGN KEY (product_variant_id) REFERENCES product_variants(id)
);

-- 7. REVIEWS & FEEDBACK
CREATE TABLE reviews (
    id BIGINT IDENTITY(1,1) PRIMARY KEY,
    user_id BIGINT NOT NULL,
    product_id BIGINT NOT NULL,
    order_item_id BIGINT UNIQUE NOT NULL, -- Only review if purchased
    rating INT CHECK (rating BETWEEN 1 AND 5),
    comment NVARCHAR(MAX),
    ai_sentiment NVARCHAR(50), -- POSITIVE, NEGATIVE, NEUTRAL
    created_at DATETIME2 DEFAULT GETDATE(),
    FOREIGN KEY (user_id) REFERENCES users(id),
    FOREIGN KEY (product_id) REFERENCES products(id),
    FOREIGN KEY (order_item_id) REFERENCES order_items(id)
);

-- 8. SYSTEM & AUDIT
CREATE TABLE notifications (
    id BIGINT IDENTITY(1,1) PRIMARY KEY,
    user_id BIGINT NOT NULL,
    title NVARCHAR(255),
    content NVARCHAR(MAX),
    type NVARCHAR(50), -- ORDER_STATUS, PROMOTION, SYSTEM
    is_read BIT DEFAULT 0,
    created_at DATETIME2 DEFAULT GETDATE(),
    FOREIGN KEY (user_id) REFERENCES users(id) ON DELETE CASCADE
);

CREATE TABLE order_status_logs (
    id BIGINT IDENTITY(1,1) PRIMARY KEY,
    order_id BIGINT NOT NULL,
    status NVARCHAR(50) NOT NULL,
    note NVARCHAR(MAX),
    created_at DATETIME2 DEFAULT GETDATE(),
    FOREIGN KEY (order_id) REFERENCES orders(id) ON DELETE CASCADE
);

CREATE TABLE inventory_logs (
    id BIGINT IDENTITY(1,1) PRIMARY KEY,
    product_variant_id BIGINT NOT NULL,
    change_amount INT NOT NULL,
    type NVARCHAR(50), -- IMPORT, EXPORT, SALE, RETURN
    created_at DATETIME2 DEFAULT GETDATE(),
    FOREIGN KEY (product_variant_id) REFERENCES product_variants(id)
);

-- 9. PERFORMANCE INDEXES
CREATE INDEX idx_product_slug ON products(slug);
CREATE INDEX idx_category_slug ON categories(slug);
CREATE INDEX idx_order_code ON orders(order_code);
CREATE INDEX idx_user_email ON users(email);
CREATE INDEX idx_shop_slug ON shops(slug);
